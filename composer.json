{
    "name": "scal-e/cdp",
    "description": "Simplified Customer Data Platform — native PHP 8 MVC, no framework",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "predis/predis": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
